BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=your_bot_username

# USER_MODE is set automatically by the setup wizard on first run.
# Values: local, cloud (or "developer" if you have multiple API keys)
USER_MODE=

# === LOCAL MODE (no keys needed) ===
# OLLAMA_MODEL_NAME is auto-detected based on your RAM
OLLAMA_MODEL_NAME=gemma3:4b
OLLAMA_VISION_MODEL_NAME=moondream
OLLAMA_HOST=http://localhost:11434

# === CLOUD MODE (paste your free Groq key) ===
# Get it free at: https://console.groq.com/keys
# GROQ_API_KEY_1=your_groq_key_here

# === DEVELOPER MODE (auto-detected if 2+ keys below are set) ===
# GROQ_API_KEY_1=
# GROQ_API_KEY_2=
# GEMINI_API_KEY=
# GITHUB_API_KEY=

# Optional PIN for extra security
# Leave empty for no PIN
OPENDESK_PIN=

OPENDESK_PROXY_URL=https://your-proxy.onrender.com
